{
  "name": "mangostudio.dev",
  "private": true,
  "license": "MIT",
  "version": "0.1.0",
  "description": "Marketing and docs website for MangoStudio — your local AI studio in a single binary.",
  "author": "Julio Polycarpo",
  "homepage": "https://mangostudio.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juliopolycarpo/mangostudio.dev.git"
  },
  "bugs": {
    "url": "https://github.com/juliopolycarpo/mangostudio.dev/issues"
  },
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && tsgo --noEmit && biome check . && dprint check",
    "qa": "bun run check && bun run test && bun run build && bun run audit:static && bun run labels:check && bun run cloudflare:dry-run",
    "typecheck": "astro check && tsgo --noEmit",
    "lint": "biome check .",
    "test": "bun ./scripts/audit-static-site.test.ts",
    "fix": "biome check --write . && dprint fmt",
    "format": "biome format --write . && dprint fmt",
    "audit:static": "bun ./scripts/audit-static-site.ts",
    "labels:check": "bun ./scripts/sync-labels.ts --dry-run",
    "labels:sync": "bun ./scripts/sync-labels.ts",
    "cloudflare:dry-run": "wrangler deploy --dry-run --outdir .wrangler-dry",
    "deploy": "astro build && wrangler deploy",
    "deploy:dry-run": "bun run build && bun run cloudflare:dry-run",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@biomejs/biome": "^2.5.0",
    "@dprint/markdown": "^0.22.1",
    "@dprint/toml": "^0.7.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@typescript/native-preview": "^7.0.0-dev.20260622.1",
    "astro": "^7.0.0",
    "dprint": "^0.54.0",
    "lefthook": "^2.1.9",
    "typescript": "~6.0.3",
    "wrangler": "^4.103.0"
  }
}

---
interface Props {
  size?: number;
  detailed?: boolean;
  class?: string;
}

const { size = 28, detailed = false, class: className } = Astro.props;
---

<svg viewBox="0 0 40 40" width={size} height={size} class={className} aria-hidden="true">
  <path
    d="M28 13 C33 20 30.5 33 20 34.6 C10 36 5 28.4 7.4 20 C9.4 12.8 17.4 9.4 24 11.3 C25.6 11.8 27 12.2 28 13 Z"
    fill="var(--mango)"></path>
  {
    detailed && (
      <>
        <path
          d="M16 33 C9 30 7 22 9.6 15.5 C11 18 11 25 14.4 30.5 C15 31.6 15.4 32.4 16 33 Z"
          fill="#ffffff"
          opacity=".14"
        />
        <ellipse
          cx="14.5"
          cy="18"
          rx="2.3"
          ry="4.4"
          transform="rotate(-22 14.5 18)"
          fill="var(--mango-light)"
          opacity=".6"
        />
      </>
    )
  }
  <path
    d="M26.4 10.6 C29 7.6 33 8 34.6 10 C32.6 13.6 28 13.6 25.8 11.4 C26 11 26.1 10.9 26.4 10.6 Z"
    fill="var(--lime)"></path>
  {
    detailed && (
      <path
        d="M25.6 11.4 C28 9.2 30.4 8.4 32.6 8.2"
        stroke="#6FA838"
        stroke-width="1.2"
        fill="none"
        stroke-linecap="round"
      />
    )
  }
</svg>

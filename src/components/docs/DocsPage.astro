---
import Icon from '@/components/Icon.astro';
import type { DocsEntry } from '@/data/docs';
import { docsNav, previousNextDocs } from '@/data/docs';
import type { Lang, SiteContent } from '@/i18n/types';
import { routes } from '@/i18n/ui';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  lang: Lang;
  content: SiteContent;
  entry: DocsEntry;
  Content: any;
  headings: Heading[];
}

const { lang, content: c, entry, Content, headings } = Astro.props;
const nav = docsNav(lang);
const slug = entry.data.slug;
const { previous, next } = previousNextDocs(lang, slug);
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3).slice(0, 12);
---

<div class="docs">
  <aside class="docs-sidebar">
    <button type="button" class="docs-search" data-cmdk-open aria-haspopup="dialog">
      <Icon name="search" size={13} />
      <span class="docs-search-label">{c.docs.searchSidebar}</span>
      <kbd>⌘K</kbd>
    </button>

    {
      nav.map((group) => (
        <div class="docs-group">
          <div class="docs-group-title">{group.title}</div>
          <div class="docs-group-items">
            {group.items.map((item) => (
              <a
                href={routes.doc(lang, item.slug)}
                class:list={['docs-link', { 'is-active': item.slug === slug }]}
                aria-current={item.slug === slug ? 'page' : undefined}
              >
                <span class="docs-link-label">{item.sidebarLabel}</span>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </aside>

  <article class="docs-article">
    <div class="docs-meta">
      <div class="docs-breadcrumb mono">
        {entry.data.groupTitle} / <span class="accent">{entry.data.sidebarLabel}</span>
      </div>
      <a class="docs-source mono" href={entry.data.sourceUrl} target="_blank" rel="noopener">
        {c.docs.sourceLabel}
      </a>
    </div>

    <div class="docs-markdown">
      <Content />
    </div>

    <div class="docs-pager">
      {
        previous ? (
          <a class="docs-pager-link" href={routes.doc(lang, previous.slug)}>
            <span class="docs-pager-dir">{c.docs.previousLabel}</span>
            <span class="docs-pager-title">{previous.sidebarLabel}</span>
          </a>
        ) : (
          <span></span>
        )
      }
      {
        next && (
          <a class="docs-pager-link docs-pager-next" href={routes.doc(lang, next.slug)}>
            <span class="docs-pager-dir">{c.docs.nextLabel}</span>
            <span class="docs-pager-title">{next.sidebarLabel}</span>
          </a>
        )
      }
    </div>
  </article>

  <aside class="docs-toc">
    {
      toc.length > 0 && (
        <div class="docs-toc-inner">
          <div class="docs-toc-title">{c.docs.tocTitle}</div>
          <div class="docs-toc-list">
            {toc.map((heading, index) => (
              <a
                class:list={[
                  'docs-toc-item',
                  `depth-${heading.depth}`,
                  { 'is-active': index === 0 },
                ]}
                href={`#${heading.slug}`}
              >
                {heading.text}
              </a>
            ))}
          </div>
        </div>
      )
    }
  </aside>
</div>

<style>
  .docs {
    display: grid;
    grid-template-columns: 266px minmax(0, 1fr) 220px;
    max-width: 1360px;
    margin: 0 auto;
  }

  .docs-sidebar {
    border-right: 1px solid var(--border);
    padding: 30px 18px 60px;
    align-self: start;
    position: sticky;
    top: var(--header-h);
    max-height: calc(100vh - var(--header-h));
    overflow-y: auto;
  }

  .docs-search {
    display: flex;
    align-items: center;
    gap: 9px;
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 9px;
    padding: 8px 11px;
    color: var(--text-3);
    font-family: inherit;
    font-size: 13px;
    cursor: pointer;
    margin-bottom: 22px;
  }

  .docs-search-label {
    flex: 1;
    text-align: left;
  }

  .docs-group {
    margin-bottom: 20px;
  }

  .docs-group-title {
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-3);
    margin-bottom: 8px;
    padding: 0 8px;
  }

  .docs-group-items {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .docs-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 6px;
    text-align: left;
    text-decoration: none;
    font-size: 13.5px;
    color: var(--text-2);
    padding: 7px 9px;
    border-radius: 7px;
    font-weight: 500;
  }

  .docs-link-label {
    flex: 1;
    min-width: 0;
  }

  .docs-link:hover {
    color: var(--text);
    background: color-mix(in srgb, var(--mango) 6%, transparent);
  }

  .docs-link.is-active {
    color: var(--text);
    font-weight: 600;
    background: color-mix(in srgb, var(--mango) 10%, transparent);
  }

  .docs-link.is-active::before {
    content: "";
    position: absolute;
    left: 0;
    top: 6px;
    bottom: 6px;
    width: 2px;
    border-radius: 2px;
    background: var(--mango);
  }

  .docs-article {
    padding: 38px 52px 80px;
    min-width: 0;
  }

  .docs-meta {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: center;
    margin-bottom: 12px;
  }

  .docs-breadcrumb,
  .docs-source {
    font-size: 12.5px;
    color: var(--text-3);
  }

  .docs-source {
    text-decoration: none;
    white-space: nowrap;
  }

  .docs-source:hover {
    color: var(--accent-text);
  }

  .accent {
    color: var(--accent-text);
  }

  .docs-markdown :global(h1) {
    margin: 12px 0 0;
    font-size: 38px;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.15;
  }

  .docs-markdown :global(h2) {
    margin: 38px 0 0;
    font-size: 23px;
    font-weight: 600;
    letter-spacing: 0;
    border-top: 1px solid var(--border);
    padding-top: 30px;
    line-height: 1.25;
  }

  .docs-markdown :global(h3) {
    margin: 28px 0 0;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.35;
  }

  .docs-markdown :global(h4) {
    margin: 24px 0 0;
    font-size: 15.5px;
    font-weight: 650;
  }

  .docs-markdown :global(p),
  .docs-markdown :global(li) {
    font-size: 15px;
    line-height: 1.68;
    color: var(--text-2);
  }

  .docs-markdown :global(p) {
    margin: 14px 0 0;
  }

  .docs-markdown :global(ul),
  .docs-markdown :global(ol) {
    margin: 14px 0 0;
    padding-left: 24px;
  }

  .docs-markdown :global(li + li) {
    margin-top: 6px;
  }

  .docs-markdown :global(a) {
    color: var(--accent-text);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .docs-markdown :global(strong) {
    color: var(--text);
  }

  .docs-markdown :global(hr) {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 32px 0;
  }

  .docs-markdown :global(blockquote) {
    margin: 18px 0 0;
    border-left: 3px solid var(--mango);
    background: color-mix(in srgb, var(--mango) 7%, transparent);
    padding: 13px 16px;
    border-radius: 0 8px 8px 0;
  }

  .docs-markdown :global(blockquote p) {
    margin: 0;
  }

  .docs-markdown :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--text);
    background: color-mix(in srgb, var(--mango) 8%, var(--surface));
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 0.08em 0.32em;
  }

  .docs-markdown :global(pre) {
    margin: 16px 0 0;
    border: 1px solid var(--border);
    border-radius: 11px;
    background: var(--code-bg);
    overflow-x: auto;
    padding: 14px 16px;
  }

  .docs-markdown :global(pre code) {
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--text);
    background: transparent;
    border: 0;
    padding: 0;
  }

  .docs-markdown :global(table) {
    display: block;
    width: 100%;
    overflow-x: auto;
    margin: 18px 0 0;
    border-collapse: collapse;
    font-size: 14px;
  }

  .docs-markdown :global(th),
  .docs-markdown :global(td) {
    border: 1px solid var(--border);
    padding: 9px 11px;
    vertical-align: top;
    color: var(--text-2);
  }

  .docs-markdown :global(th) {
    color: var(--text);
    font-weight: 600;
    background: var(--surface);
  }

  .docs-pager {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 48px;
    border-top: 1px solid var(--border);
    padding-top: 24px;
  }

  .docs-pager-link {
    display: flex;
    flex-direction: column;
    gap: 3px;
    text-decoration: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 18px;
    color: var(--text);
    min-width: 0;
  }

  .docs-pager-link:hover {
    border-color: color-mix(in srgb, var(--mango) 45%, var(--border));
  }

  .docs-pager-next {
    text-align: right;
  }

  .docs-pager-dir {
    font-size: 12px;
    color: var(--text-3);
  }

  .docs-pager-title {
    font-size: 14.5px;
    font-weight: 600;
  }

  .docs-toc {
    padding: 38px 18px 60px;
    align-self: start;
    position: sticky;
    top: var(--header-h);
  }

  .docs-toc-title {
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-3);
    margin-bottom: 12px;
  }

  .docs-toc-list {
    display: flex;
    flex-direction: column;
    gap: 9px;
    border-left: 1px solid var(--border);
    padding-left: 14px;
  }

  .docs-toc-item {
    font-size: 13px;
    color: var(--text-3);
    text-decoration: none;
    line-height: 1.35;
  }

  .docs-toc-item.depth-3 {
    padding-left: 12px;
  }

  .docs-toc-item:hover,
  .docs-toc-item.is-active {
    color: var(--accent-text);
  }

  @media (max-width: 1120px) {
    .docs {
      grid-template-columns: 266px minmax(0, 1fr);
    }
    .docs-toc {
      display: none;
    }
  }

  @media (max-width: 820px) {
    .docs {
      grid-template-columns: 1fr;
    }
    .docs-sidebar {
      position: static;
      max-height: none;
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
    .docs-article {
      padding: 32px 24px 64px;
    }
    .docs-meta {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
    }
  }

  @media (max-width: 560px) {
    .docs-markdown :global(h1) {
      font-size: 31px;
    }
    .docs-pager {
      grid-template-columns: 1fr;
    }
    .docs-pager-next {
      text-align: left;
    }
  }
</style>

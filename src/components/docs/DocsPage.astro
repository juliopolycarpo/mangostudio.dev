---
import CopyButton from '@/components/CopyButton.astro';
import Icon from '@/components/Icon.astro';
import type { Lang, SiteContent } from '@/i18n/types';
import { routes } from '@/i18n/ui';

interface Props {
  lang: Lang;
  content: SiteContent;
  docId: string;
}

const { lang, content: c, docId } = Astro.props;
const q = c.docs.quickstart;
const isQuickstart = docId === 'quickstart';

let stubLabel = docId;
for (const group of c.docs.groups) {
  for (const item of group.items) {
    if (item.id === docId) stubLabel = item.label;
  }
}

const crumbs = q.breadcrumb.split('/').map((part) => part.trim());
const crumbLead = crumbs.slice(0, -1).join(' / ');
const crumbLast = crumbs[crumbs.length - 1];
---

<div class="docs">
  <aside class="docs-sidebar">
    <button type="button" class="docs-search" data-cmdk-open aria-haspopup="dialog">
      <Icon name="search" size={13} />
      <span class="docs-search-label">{c.docs.searchSidebar}</span>
      <kbd>⌘K</kbd>
    </button>

    {
      c.docs.groups.map((group) => (
        <div class="docs-group">
          <div class="docs-group-title">{group.title}</div>
          <div class="docs-group-items">
            {group.items.map((item) => (
              <a
                href={routes.doc(lang, item.id)}
                class:list={['docs-link', { 'is-active': item.id === docId }]}
                aria-current={item.id === docId ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </aside>

  <article class="docs-article">
    {
      isQuickstart ? (
        <>
          <div class="docs-breadcrumb mono">
            {crumbLead} / <span class="accent">{crumbLast}</span>
          </div>
          <h1 class="docs-h1">{q.title}</h1>
          <p class="docs-lead">{q.intro}</p>

          <div class="docs-callout">
            <span class="docs-callout-icon">
              <Icon name="info" size={19} />
            </span>
            <p>
              <strong>{q.prereqStrong}</strong>
              {q.prereqText}
            </p>
          </div>

          {q.sections.map((section) => (
            <Fragment>
              <h2 class="docs-h2">{section.title}</h2>
              <p class="docs-p">{section.body}</p>
              <div class="docs-code-block">
                <div class="docs-code-bar">
                  <span class="mono docs-code-lang">{section.codeLang}</span>
                  <CopyButton text={section.code} label="Copy" size="sm" />
                </div>
                <pre class="docs-pre"><code class="mono">{section.code}</code></pre>
              </div>
            </Fragment>
          ))}

          <div class="docs-pager">
            <a class="docs-pager-link" href={routes.doc(lang, 'install')}>
              <span class="docs-pager-dir">{q.prevLabel}</span>
              <span class="docs-pager-title">{q.prevTitle}</span>
            </a>
            <a class="docs-pager-link docs-pager-next" href={routes.doc(lang, 'chat')}>
              <span class="docs-pager-dir">{q.nextLabel}</span>
              <span class="docs-pager-title">{q.nextTitle}</span>
            </a>
          </div>
        </>
      ) : (
        <>
          <div class="docs-breadcrumb mono">
            Docs / <span class="accent">{stubLabel}</span>
          </div>
          <h1 class="docs-h1">{stubLabel}</h1>
          <div class="docs-stub">
            <span class="docs-stub-badge mono">{c.docs.stubBadge}</span>
            <span>{c.docs.stubText}</span>
          </div>
        </>
      )
    }
  </article>

  <aside class="docs-toc">
    {
      isQuickstart && (
        <div class="docs-toc-inner">
          <div class="docs-toc-title">{q.tocTitle}</div>
          <div class="docs-toc-list">
            {q.toc.map((entry, index) => (
              <span class:list={['docs-toc-item', { 'is-active': index === 0 }]}>{entry}</span>
            ))}
          </div>
        </div>
      )
    }
  </aside>
</div>

<style>
  .docs {
    display: grid;
    grid-template-columns: 248px minmax(0, 1fr) 200px;
    max-width: 1280px;
    margin: 0 auto;
  }

  .docs-sidebar {
    border-right: 1px solid var(--border);
    padding: 30px 18px 60px;
    align-self: start;
    position: sticky;
    top: var(--header-h);
    max-height: calc(100vh - var(--header-h));
    overflow-y: auto;
  }

  .docs-search {
    display: flex;
    align-items: center;
    gap: 9px;
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 9px;
    padding: 8px 11px;
    color: var(--text-3);
    font-family: inherit;
    font-size: 13px;
    cursor: pointer;
    margin-bottom: 22px;
  }

  .docs-search-label {
    flex: 1;
    text-align: left;
  }

  .docs-group {
    margin-bottom: 20px;
  }

  .docs-group-title {
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-3);
    margin-bottom: 8px;
    padding: 0 8px;
  }

  .docs-group-items {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .docs-link {
    position: relative;
    text-align: left;
    text-decoration: none;
    font-size: 13.5px;
    color: var(--text-2);
    padding: 7px 9px;
    border-radius: 7px;
    font-weight: 500;
  }

  .docs-link:hover {
    color: var(--text);
    background: color-mix(in srgb, var(--mango) 6%, transparent);
  }

  .docs-link.is-active {
    color: var(--text);
    font-weight: 600;
    background: color-mix(in srgb, var(--mango) 10%, transparent);
  }

  .docs-link.is-active::before {
    content: "";
    position: absolute;
    left: 0;
    top: 6px;
    bottom: 6px;
    width: 2px;
    border-radius: 2px;
    background: var(--mango);
  }

  .docs-article {
    padding: 38px 48px 80px;
    min-width: 0;
  }

  .docs-breadcrumb {
    font-size: 12.5px;
    color: var(--text-3);
  }

  .accent {
    color: var(--mango);
  }

  .docs-h1 {
    margin: 12px 0 0;
    font-size: 38px;
    font-weight: 600;
    letter-spacing: -0.025em;
  }

  .docs-lead {
    margin: 14px 0 0;
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--text-2);
  }

  .docs-callout {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-top: 28px;
    border: 1px solid color-mix(in srgb, var(--mango) 30%, transparent);
    background: color-mix(in srgb, var(--mango) 8%, transparent);
    border-radius: 12px;
    padding: 15px 18px;
  }

  .docs-callout-icon {
    color: var(--mango);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .docs-callout p {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text-2);
  }

  .docs-callout strong {
    color: var(--text);
  }

  .docs-h2 {
    margin: 38px 0 0;
    font-size: 23px;
    font-weight: 600;
    letter-spacing: -0.01em;
    border-top: 1px solid var(--border);
    padding-top: 30px;
  }

  .docs-p {
    margin: 12px 0 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-2);
  }

  .docs-code-block {
    margin-top: 14px;
    border: 1px solid var(--border);
    border-radius: 11px;
    background: var(--code-bg);
    overflow: hidden;
  }

  .docs-code-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
  }

  .docs-code-lang {
    font-size: 11.5px;
    color: var(--text-3);
  }

  .docs-pre {
    margin: 0;
    padding: 14px 16px;
    overflow-x: auto;
  }

  .docs-pre code {
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--text);
  }

  .docs-pager {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    margin-top: 48px;
    border-top: 1px solid var(--border);
    padding-top: 24px;
  }

  .docs-pager-link {
    display: flex;
    flex-direction: column;
    gap: 3px;
    text-decoration: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 11px;
    padding: 14px 18px;
    color: var(--text);
  }

  .docs-pager-link:hover {
    border-color: color-mix(in srgb, var(--mango) 45%, var(--border));
  }

  .docs-pager-next {
    text-align: right;
  }

  .docs-pager-dir {
    font-size: 12px;
    color: var(--text-3);
  }

  .docs-pager-title {
    font-size: 14.5px;
    font-weight: 600;
  }

  .docs-stub {
    margin-top: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px dashed var(--border);
    border-radius: 12px;
    padding: 22px;
    color: var(--text-3);
    font-size: 14.5px;
  }

  .docs-stub-badge {
    flex-shrink: 0;
    font-size: 11px;
    color: var(--mango);
    border: 1px solid color-mix(in srgb, var(--mango) 35%, transparent);
    border-radius: 5px;
    padding: 3px 8px;
  }

  .docs-toc {
    padding: 38px 18px 60px;
    align-self: start;
    position: sticky;
    top: var(--header-h);
  }

  .docs-toc-title {
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-3);
    margin-bottom: 12px;
  }

  .docs-toc-list {
    display: flex;
    flex-direction: column;
    gap: 9px;
    border-left: 1px solid var(--border);
    padding-left: 14px;
  }

  .docs-toc-item {
    font-size: 13px;
    color: var(--text-3);
  }

  .docs-toc-item.is-active {
    color: var(--mango);
    font-weight: 500;
  }

  @media (max-width: 1100px) {
    .docs {
      grid-template-columns: 248px minmax(0, 1fr);
    }
    .docs-toc {
      display: none;
    }
  }

  @media (max-width: 820px) {
    .docs {
      grid-template-columns: 1fr;
    }
    .docs-sidebar {
      position: static;
      max-height: none;
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
    .docs-article {
      padding: 32px 24px 64px;
    }
  }
</style>

---
import type { CmdkAction, Lang, SiteContent } from '@/i18n/types';
import { findDocItem, isDocReady, routes } from '@/i18n/ui';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
  content: SiteContent;
}

const { lang, content: c } = Astro.props;

function hrefFor(action: CmdkAction): string | undefined {
  switch (action.type) {
    case 'nav':
      return action.page === 'home' ? routes.home(lang) : routes.releases(lang);
    case 'doc':
      return routes.doc(lang, action.doc);
    case 'external':
      return action.href;
    case 'theme':
      return undefined;
  }
}

const plannedSearch = c.docs.plannedBadge.toLowerCase();

const items = c.cmdk.items.map((item) => {
  const docItem =
    item.action.type === 'doc' ? findDocItem(c.docs.groups, item.action.doc) : undefined;
  const planned = docItem !== undefined && !isDocReady(docItem);

  return {
    ...item,
    href: hrefFor(item.action),
    external: item.action.type === 'external',
    isTheme: item.action.type === 'theme',
    planned,
    search: `${item.title} ${item.sub} ${item.kind}${planned ? ` ${plannedSearch}` : ''}`.toLowerCase(),
  };
});
---

<dialog id="cmdk" class="cmdk" aria-label="Command menu">
  <div class="cmdk-panel">
    <div class="cmdk-search">
      <Icon name="search" size={17} />
      <input
        type="text"
        class="cmdk-input"
        data-cmdk-input
        placeholder={c.cmdk.placeholder}
        autocomplete="off"
        role="combobox"
        aria-expanded="false"
        aria-controls="cmdk-list"
        aria-autocomplete="list"
        aria-label={c.cmdk.placeholder}
      />
      <kbd>esc</kbd>
    </div>

    <div class="cmdk-results" id="cmdk-list" role="listbox">
      {
        items.map((item, index) => {
          const body = (
            <>
              <span class="cmdk-glyph">{item.glyph}</span>
              <span class="cmdk-text">
                <span class="cmdk-title">{item.title}</span>
                <span class="cmdk-sub-row">
                  <span class="cmdk-sub">{item.sub}</span>
                  {item.planned && (
                    <span class="cmdk-planned-pill mono" aria-label={c.docs.plannedSidebarHint}>
                      {c.docs.plannedBadge}
                    </span>
                  )}
                </span>
              </span>
              <span class="cmdk-kind">{item.kind}</span>
            </>
          );

          return item.isTheme ? (
            <button
              type="button"
              class="cmdk-item"
              id={`cmdk-option-${index}`}
              role="option"
              aria-selected="false"
              data-cmdk-item
              data-action="theme"
              data-search={item.search}
            >
              {body}
            </button>
          ) : (
            <a
              class="cmdk-item"
              id={`cmdk-option-${index}`}
              role="option"
              aria-selected="false"
              data-cmdk-item
              data-search={item.search}
              href={item.href}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noopener' : undefined}
            >
              {body}
            </a>
          );
        })
      }
      <div class="cmdk-empty" data-cmdk-empty hidden>
        {c.cmdk.noResults} “<span data-cmdk-query></span>”.
      </div>
    </div>

    <div class="cmdk-footer">
      <span>{c.cmdk.open}</span>
      <span>{c.cmdk.close}</span>
      <span class="cmdk-brand">{c.cmdk.footer}</span>
    </div>
  </div>
</dialog>

<style>
  .cmdk {
    margin: 14vh auto auto;
    padding: 0;
    border: none;
    background: transparent;
    width: min(560px, 92vw);
    max-width: 92vw;
    color: var(--text);
  }

  .cmdk::backdrop {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
  }

  .cmdk-panel {
    background: var(--elevated);
    border: 1px solid var(--border);
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 30px 80px -20px rgba(0, 0, 0, 0.7);
  }

  .cmdk[open] .cmdk-panel {
    animation: fadeup 0.15s ease both;
  }

  .cmdk-search {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 15px 17px;
    border-bottom: 1px solid var(--border);
    color: var(--text-3);
  }

  .cmdk-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--text);
    font-family: inherit;
    font-size: 15px;
  }

  .cmdk-results {
    max-height: 340px;
    overflow-y: auto;
    padding: 8px;
  }

  .cmdk-item {
    display: flex;
    align-items: center;
    gap: 13px;
    width: 100%;
    text-align: left;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    padding: 11px 12px;
    border-radius: 9px;
    color: var(--text);
  }

  .cmdk-item:hover,
  .cmdk-item:focus-visible,
  .cmdk-item.is-active {
    background: var(--surface);
  }

  .cmdk-glyph {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--mango);
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .cmdk-text {
    flex: 1;
  }

  .cmdk-title {
    display: block;
    font-size: 14px;
    font-weight: 500;
  }

  .cmdk-sub-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    min-width: 0;
  }

  .cmdk-sub {
    font-size: 12px;
    color: var(--text-3);
    min-width: 0;
  }

  .cmdk-planned-pill {
    flex-shrink: 0;
    font-size: 9.5px;
    font-weight: 600;
    color: var(--mango);
    border: 1px solid color-mix(in srgb, var(--mango) 35%, transparent);
    border-radius: 4px;
    padding: 1px 5px;
    letter-spacing: 0.02em;
  }

  .cmdk-kind {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-3);
    text-transform: uppercase;
  }

  .cmdk-empty {
    padding: 26px;
    text-align: center;
    font-size: 13.5px;
    color: var(--text-3);
  }

  .cmdk-footer {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 10px 15px;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-3);
  }

  .cmdk-brand {
    margin-left: auto;
  }
</style>

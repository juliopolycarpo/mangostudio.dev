---
import { getImage } from 'astro:assets';
import Icon from '@/components/Icon.astro';
import { siteAssets } from '@/data/assets';
import type { SiteContent } from '@/i18n/types';

interface Props {
  content: SiteContent;
}

const { content: c } = Astro.props;
const usLogo = await getImage({ src: siteAssets.icon192, width: 18, height: 18 });
---

<section class="compare container">
  <div class="compare-head">
    <div class="eyebrow">{c.comparison.eyebrow}</div>
    <h2 class="section-title">{c.comparison.title}</h2>
  </div>

  <div class="compare-table">
    <div class="compare-row compare-header">
      <span class="compare-crit mono">{c.comparison.criterion}</span>
      <span class="compare-us">
        <img src={usLogo.src} alt="" width="18" height="18" loading="lazy" decoding="async" />
        {c.comparison.us}
      </span>
      <span class="compare-them">{c.comparison.them}</span>
    </div>
    {
      c.comparison.rows.map((row) => (
        <div class="compare-row">
          <span class="compare-label">{row.label}</span>
          <span class="compare-yes">
            <Icon name="check" size={17} />
            {row.us}
          </span>
          <span class="compare-no">
            <Icon name="x" size={16} />
            {row.them}
          </span>
        </div>
      ))
    }
  </div>
</section>

<style>
  .compare {
    padding: 24px 24px 72px;
  }

  .compare-head {
    margin-bottom: 30px;
  }

  .compare-table {
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    background: var(--surface);
  }

  .compare-row {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    align-items: center;
    padding: 15px 22px;
    border-bottom: 1px solid var(--border);
  }

  .compare-row:last-child {
    border-bottom: none;
  }

  .compare-header {
    padding: 16px 22px;
    background: var(--bg);
  }

  .compare-crit {
    font-size: 13px;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .compare-us {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 14.5px;
  }

  .compare-them {
    font-weight: 500;
    font-size: 14.5px;
    color: var(--text-2);
  }

  .compare-label {
    font-size: 14.5px;
  }

  .compare-yes {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    color: var(--success-text);
    font-weight: 500;
  }

  .compare-no {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    color: var(--text-3);
  }

  @media (max-width: 640px) {
    .compare-row {
      grid-template-columns: 1.3fr 1fr 1fr;
      padding: 13px 16px;
      font-size: 12px;
    }
    .compare-label,
    .compare-us,
    .compare-them {
      font-size: 13px;
    }
  }
</style>

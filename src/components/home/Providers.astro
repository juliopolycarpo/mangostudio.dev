---
import { PROVIDERS } from '@/data/site';
import type { SiteContent } from '@/i18n/types';

interface Props {
  content: SiteContent;
}

const { content: c } = Astro.props;
---

<section class="providers container">
  <div class="card providers-card">
    <div class="eyebrow providers-eyebrow">{c.providers.eyebrow}</div>
    <h2 class="providers-title">{c.providers.title}</h2>
    <div class="providers-list">
      {
        PROVIDERS.map((provider) => (
          <div class="provider">
            <span class="provider-glyph mono">{provider.glyph}</span>
            <span class="provider-name">{provider.name}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .providers {
    padding: 8px 24px 72px;
  }

  .providers-card {
    padding: 34px;
    text-align: center;
    border-radius: 18px;
  }

  .providers-eyebrow {
    color: var(--text-3);
  }

  .providers-title {
    margin: 8px 0 26px;
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .providers-list {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .provider {
    display: flex;
    align-items: center;
    gap: 11px;
    border: 1px solid var(--border);
    background: var(--bg);
    border-radius: 11px;
    padding: 11px 17px;
  }

  .provider-glyph {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--mango) 13%, transparent);
    color: var(--mango);
    font-weight: 600;
    font-size: 14px;
  }

  .provider-name {
    font-size: 14.5px;
    font-weight: 500;
  }
</style>

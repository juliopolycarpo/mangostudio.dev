---
import CopyButton from '@/components/CopyButton.astro';
import { INSTALL_TABS } from '@/data/site';
import type { SiteContent } from '@/i18n/types';

interface Props {
  content: SiteContent;
}

const { content: c } = Astro.props;
const initial = INSTALL_TABS[0];
---

<div class="install">
  <div class="terminal-bar">
    <span class="traffic red"></span>
    <span class="traffic yellow"></span>
    <span class="traffic green"></span>
    <span class="terminal-title">{c.hero.terminalTitle}</span>
  </div>

  <div class="install-tabs" id="install-tabs" role="tablist" aria-label={c.hero.terminalTitle}>
    {
      INSTALL_TABS.map((tab, index) => {
        const isPlanned = tab.status === 'planned';
        const tabId = `install-tab-${tab.id}`;
        return (
          <button
            type="button"
            class:list={['install-tab', { 'is-active': index === 0, 'is-planned': isPlanned }]}
            id={tabId}
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            aria-controls="install-panel"
            aria-disabled={isPlanned ? 'true' : undefined}
            tabindex={index === 0 ? 0 : -1}
            data-channel={tab.id}
            data-cmd={tab.cmd}
            data-status={tab.status}
          >
            {tab.label}
            {isPlanned && <span class="planned-pill">{c.channels.plannedLabel}</span>}
          </button>
        );
      })
    }
  </div>

  <div
    class="install-cmd"
    id="install-panel"
    role="tabpanel"
    aria-labelledby={`install-tab-${initial.id}`}
    data-state={initial.status}
  >
    <code class="install-code">
      <span class="prompt">$ </span><span id="hero-cmd">{initial.cmd}</span>
    </code>
    <span class="install-hint" id="hero-hint">{c.channels.plannedHint}</span>
    <CopyButton text={initial.cmd} label={c.copyButtonLabel} id="hero-copy" />
  </div>
</div>

<style>
  .install {
    max-width: 640px;
    margin: 34px auto 0;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--code-bg);
    overflow: hidden;
    box-shadow: 0 30px 70px -28px var(--shadow), 0 0 0 1px var(--hair);
    text-align: left;
    min-height: 176px;
  }

  .install-tabs {
    display: flex;
    gap: 2px;
    padding: 8px 10px 0;
    flex-wrap: wrap;
  }

  .install-tab {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--text-3);
    padding: 7px 12px 9px;
    border-radius: 7px 7px 0 0;
    font-weight: 500;
  }

  .install-tab:hover {
    color: var(--text-2);
  }

  .install-tab.is-active {
    color: var(--text);
    font-weight: 600;
  }

  .install-tab.is-active::after {
    content: "";
    position: absolute;
    left: 6px;
    right: 6px;
    bottom: 0;
    height: 2px;
    border-radius: 2px;
    background: var(--mango);
  }

  .install-tab.is-planned {
    color: var(--text-3);
    cursor: not-allowed;
  }

  .install-tab.is-planned.is-active {
    color: var(--text-2);
  }

  .planned-pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--text-3) 18%, transparent);
    color: var(--text-3);
    font-weight: 500;
  }

  .install-cmd {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 16px 18px;
    border-top: 1px solid var(--border);
    min-height: 66px;
  }

  .install-code {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--text);
    overflow-x: auto;
    white-space: nowrap;
  }

  .install-hint {
    flex: 1;
    font-size: 13px;
    color: var(--text-3);
    font-style: italic;
  }

  .install-cmd[data-state="ready"] .install-hint {
    display: none;
  }

  .install-cmd[data-state="planned"] .install-code,
  .install-cmd[data-state="planned"] :global(#hero-copy) {
    display: none;
  }

  .prompt {
    color: var(--accent-text);
  }
</style>

---
import { getImage } from 'astro:assets';
import { siteAssets } from '@/data/assets';
import { GITHUB_URL } from '@/data/site';
import type { Lang, SiteContent } from '@/i18n/types';
import { routes } from '@/i18n/ui';
import Icon from './Icon.astro';
import LangToggle from './LangToggle.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang: Lang;
  pathname: string;
  content: SiteContent;
  page: 'home' | 'releases' | 'docs';
}

const { lang, pathname, content: c, page } = Astro.props;

const brandLogo = await getImage({ src: siteAssets.icon192, width: 28, height: 28 });

const nav = [
  {
    label: c.nav.home,
    href: routes.home(lang),
    active: page === 'home',
    prefetch: page !== 'home',
  },
  {
    label: c.nav.features,
    href: `${routes.home(lang)}#features`,
    active: false,
    prefetch: page !== 'home',
  },
  {
    label: c.nav.releases,
    href: routes.releases(lang),
    active: page === 'releases',
    prefetch: page !== 'releases',
  },
  {
    label: c.nav.docs,
    href: routes.doc(lang, 'quickstart'),
    active: page === 'docs',
    prefetch: page !== 'docs',
  },
];
---

<header class="site-header">
  <a
    class="brand"
    href={routes.home(lang)}
    aria-label="MangoStudio"
    data-astro-prefetch={page === 'home' ? undefined : 'hover'}
  >
    <img
      src={brandLogo.src}
      alt=""
      width="28"
      height="28"
      class="brand-logo"
      decoding="async"
    />
    <span class="brand-name">Mango<span class="brand-dim">Studio</span></span>
  </a>

  <nav class="nav" aria-label="Primary">
    {
      nav.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { 'is-active': item.active }]}
          aria-current={item.active ? 'page' : undefined}
          data-astro-prefetch={item.prefetch ? 'hover' : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>

  <div class="spacer"></div>

  <button type="button" class="search-btn" data-cmdk-open aria-haspopup="dialog">
    <Icon name="search" size={14} />
    <span class="search-label">{c.header.search}</span>
    <kbd>⌘K</kbd>
  </button>

  <ThemeToggle label={c.header.theme} />
  <LangToggle lang={lang} pathname={pathname} content={c} />

  <a class="gh-link" href={GITHUB_URL} target="_blank" rel="noopener" aria-label={c.header.github}>
    <Icon name="github" size={16} />
    <span class="gh-star" aria-hidden="true">★</span>
    <span class="gh-label">{c.header.star}</span>
  </a>

  <a
    class="btn btn-primary header-cta"
    href={routes.doc(lang, 'quickstart')}
    data-astro-prefetch={page === 'docs' ? undefined : 'hover'}
  >
    {c.header.cta}
  </a>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 13px 24px;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    backdrop-filter: blur(14px) saturate(1.4);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
  }

  .brand-logo {
    display: block;
  }

  .brand-name {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .brand-dim {
    color: var(--text-2);
    font-weight: 500;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: 14px;
  }

  .nav-link {
    position: relative;
    font-size: 13.5px;
    color: var(--text-2);
    text-decoration: none;
    padding: 8px 11px;
    border-radius: 8px;
    font-weight: 500;
  }

  .nav-link:hover {
    color: var(--text);
  }

  .nav-link.is-active {
    color: var(--text);
  }

  .nav-link.is-active::after {
    content: "";
    position: absolute;
    left: 11px;
    right: 11px;
    bottom: 2px;
    height: 2px;
    border-radius: 2px;
    background: var(--mango);
  }

  .spacer {
    flex: 1;
  }

  .search-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    cursor: pointer;
    color: var(--text-3);
    font-family: inherit;
    font-size: 13px;
    padding: 7px 10px 7px 12px;
    border-radius: 9px;
    min-width: 190px;
  }

  .search-btn:hover {
    border-color: color-mix(in srgb, var(--mango) 45%, var(--border));
  }

  .search-label {
    flex: 1;
    text-align: left;
  }

  kbd {
    font-family: var(--font-mono);
    font-size: 11px;
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 1px 5px;
    color: var(--text-3);
  }

  .gh-link {
    display: flex;
    align-items: center;
    gap: 7px;
    text-decoration: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 9px;
    padding: 7px 11px;
    color: var(--text);
    font-size: 13px;
    font-weight: 500;
  }

  .gh-link:hover {
    border-color: color-mix(in srgb, var(--mango) 45%, var(--border));
  }

  .gh-star {
    font-size: 12px;
    line-height: 1;
    color: var(--accent-text);
  }

  .gh-label {
    font-size: 13px;
    color: var(--text-2);
  }

  .header-cta {
    padding: 8px 16px;
    font-size: 13.5px;
  }

  @media (max-width: 1080px) {
    .nav,
    .search-label,
    .gh-star,
    .gh-label {
      display: none;
    }
    .search-btn {
      min-width: 0;
    }
  }

  @media (max-width: 720px) {
    .site-header {
      gap: 12px;
      padding: 11px 16px;
      /* Avoid the per-scroll-frame backdrop blur repaint on phones; a near-opaque
         background keeps the sticky header legible at a fraction of the paint cost. */
      background: color-mix(in srgb, var(--bg) 94%, transparent);
      backdrop-filter: none;
    }
    .header-cta {
      display: none;
    }
  }
</style>

---
import DocsPage from '@/components/docs/DocsPage.astro';
import { findDocItem, getLangFromUrl, useContent } from '@/i18n/ui';
import BaseLayout from '@/layouts/BaseLayout.astro';

export function getStaticPaths() {
  const c = useContent('pt');
  return c.docs.groups.flatMap((group) =>
    group.items.map((item) => ({ params: { slug: item.id } }))
  );
}

const { slug } = Astro.params;
const docId = slug ?? 'quickstart';
const lang = getLangFromUrl(Astro.url);
const content = useContent(lang);

const label = findDocItem(content.docs.groups, docId)?.label ?? docId;
const title = `${label} — MangoStudio Docs`;
---

<BaseLayout page="docs" title={title}>
  <DocsPage lang={lang} content={content} docId={docId} />
</BaseLayout>
